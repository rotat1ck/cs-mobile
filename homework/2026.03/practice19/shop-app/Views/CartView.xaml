<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:shop_app.ViewModels"
             xmlns:controls="clr-namespace:shop_app.Controls"
             xmlns:models="clr-namespace:shop_app.Models"
             x:Class="shop_app.Views.CartView"
             x:DataType="viewModels:CartViewModel"
             MinimumWidthRequest="430">

    <ScrollView>
        <VerticalStackLayout>
            <!-- Вверх -->
            <Grid Padding="40,40,40,30" ColumnSpacing="10" HorizontalOptions="Fill">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Вернуться -->
                <Border Grid.Column="0" HeightRequest="56" WidthRequest="56" StrokeShape="RoundRectangle 28" 
                    StrokeThickness="0" BackgroundColor="#F6F6F6" Padding="18">
                    <Image Source="arrow_back.png" Aspect="AspectFit"/>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Лого -->
                <Image Grid.Column="1" Source="logo.png" Aspect="Center" HeightRequest="20" WidthRequest="150" HorizontalOptions="Center" />
            </Grid>

            <!-- Шмотки -->
            <ScrollView Padding="40,0,40,30" MinimumHeightRequest="270" MaximumHeightRequest="565">
                <CollectionView ItemsSource="{Binding CartService.Items}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" VerticalItemSpacing="10" HorizontalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Item">
                            <Grid ColumnSpacing="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <controls:ItemControl Grid.Column="0" ItemImageSource="{Binding ImageUri}" ItemName="{Binding Name}"
                                                      ItemPrice="{Binding Price}" ItemRating="{Binding Rating}"/>
                                <!-- Корзина -->
                                <Border Grid.Column="2" HeightRequest="56" WidthRequest="56" StrokeShape="RoundRectangle 28" 
                                        StrokeThickness="0" BackgroundColor="#F6F6F6" Padding="15">
                                    <Image Source="bag.png" Aspect="AspectFit"/>
                                    
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding RemoveFromCartCommand, Source={RelativeSource AncestorType={x:Type viewModels:CartViewModel}}}" CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                </CollectionView>
            </ScrollView>

            <!-- К оплате -->
            <Grid Padding="40,0,40,0" HeightRequest="82" >
                <Border BackgroundColor="#EB6434" StrokeShape="RoundRectangle 15" StrokeThickness="0"
                        Padding="35,30,35,30">
                    <Grid>
                        <!-- Надпись -->
                        <Label Text="CHECKOUT" FontFamily="MonumentExtended" 
                                       FontSize="14" TextColor="#FFFFFF" VerticalOptions="Center"
                                       WidthRequest="104" HorizontalOptions="Start"/>

                        <!-- Стрелочка -->
                        <Image HeightRequest="13" WidthRequest="19" 
                                   HorizontalOptions="Start" Margin="114,0,0,0"
                                   Source="arrow_checkout.png" Aspect="AspectFit"/>

                        <!-- Ценник -->
                        <Label Text="{Binding CartService.TotalPrice, StringFormat='$ {0}'}" HorizontalOptions="End"
                               FontFamily="MonumentExtended" FontSize="18"/>
                    </Grid>
                </Border>
            </Grid>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>